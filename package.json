{
  "name": "Open_Translator",
  "description": "A local-only YouTube subtitle translator powered by a localhost OpenAI-compatible proxy.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && node scripts/sync-dist.mjs",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "proxy:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-openai-oauth-hidden.ps1 -StopDuplicatePorts",
    "proxy:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-openai-oauth.ps1",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.25"
  }
}
